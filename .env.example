# ========================================
# CareerTrust Environment Variables
# ========================================

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database Configuration
# Development: SQLite (default)
DATABASE_URL=sqlite:///careertrust_dev.db
# Production: PostgreSQL on Render
# DATABASE_URL=postgresql://user:password@host:5432/careertrust

# ========================================
# SMTP Configuration (Email Notifications)
# ========================================

# Gmail (Recommended for Free)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFICATIONS_FROM_EMAIL=your_email@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ========================================
# Frontend Configuration
# ========================================
# Development
REACT_APP_API_URL=http://localhost:5000/api
# Production (Netlify)
# REACT_APP_API_URL=https://careertrust-backend.onrender.com/api

# ========================================
# Optional: External APIs
# ========================================
LINKEDIN_API_KEY=
INDEED_API_KEY=
GITHUB_JOBS_API_ENABLED=true

# Logging
LOG_LEVEL=INFO

